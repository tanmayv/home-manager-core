{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "pre-tool-placeholder",
            "type": "command",
            "command": "python3 ~/.gemini/hooks/pre_tool.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "post-tool-placeholder",
            "type": "command",
            "command": "python3 ~/.gemini/hooks/post_tool.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "pre-invocation-placeholder",
            "type": "command",
            "command": "python3 ~/.gemini/hooks/pre_invocation.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "post-invocation-placeholder",
            "type": "command",
            "command": "python3 ~/.gemini/hooks/post_invocation.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "after-agent-placeholder",
            "type": "command",
            "command": "python3 ~/.gemini/hooks/after_agent.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "ToolPermission|Allow Tool|Run Command|Confirm Edit",
        "hooks": [
          {
            "name": "notify-approval-placeholder",
            "type": "command",
            "command": "python3 ~/.gemini/hooks/notify_approval.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "session-end-placeholder",
            "type": "command",
            "command": "python3 ~/.gemini/hooks/session_end.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}

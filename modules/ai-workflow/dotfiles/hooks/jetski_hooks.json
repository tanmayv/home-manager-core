{
  "placeholder-jetski": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/placeholders/jetski_pre_tool.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/placeholders/jetski_post_tool.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreInvocation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/placeholders/pre_invocation.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostInvocation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/placeholders/post_invocation.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/placeholders/session_end.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
